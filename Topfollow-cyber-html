     </div>
     <button class="btn btn-b" onclick="loadAdminStats()"><span class="bgl"></span>STATISTIKA</button>
     <div style="border-top:1px solid rgba(255,255,255,.08);padding-top:12px;font-family:var(--FD);font-size:11px;color:var(--dim);letter-spacing:2px;margin-bottom:4px">PROMOCOD YARATISH</div>
     <div class="ig"><input type="text" class="if" id="adm-pcode" placeholder="x" autocomplete="off" style="text-transform:uppercase"><label class="il">KOD (bo'sh = avto)</label></div>
     <div class="ig"><input type="number" class="if" id="adm-pamt" placeholder="x" value="1000"><label class="il">TANGA MIQDORI</label></div>
     <button class="btn btn-g" onclick="createPromo(event)"><span class="bgl"></span>YARATISH</button>
     <div id="promo-list-wrap" style="display:none">
      <div style="font-family:var(--FD);font-size:10px;color:var(--dim);letter-spacing:2px;margin-bottom:8px">SO'NGGI PROMOKODLAR</div>
      <div class="promo-list" id="promo-list"></div>
     </div>
    </div>
   </div>
  </div>

 </div><!-- /phone -->
</div><!-- /dbg -->
<script>
const API='https://treydingazizbek.pythonanywhere.com';
let CUR={username:'',coins:0,accounts:[],pkg:null,fTarget:''};

/* ── MATRIX ── */
(function(){
 const c=document.getElementById('mc'),x=c.getContext('2d'),p=document.getElementById('phone');
 c.width=p.offsetWidth;c.height=p.offsetHeight;
 const ch='TOPFLWGHKMNQRUVXYZ0123456789#@$%',fs=11,co=Math.floor(c.width/fs);
 const dr=Array.from({length:co},()=>Math.random()*-50);
 function d(){
  x.fillStyle='rgba(3,1,10,0.08)';x.fillRect(0,0,c.width,c.height);
  x.font=fs+'px monospace';
  dr.forEach((y,i)=>{
   const r=Math.random();
   x.fillStyle=r<.15?'rgba(0,255,157,0.8)':r<.35?'rgba(0,212,255,0.5)':'rgba(180,0,255,0.35)';
   x.fillText(ch[Math.floor(Math.random()*ch.length)],i*fs,y*fs);
   if(y*fs>c.height&&Math.random()>.975)dr[i]=0;
   dr[i]+=.5;
  });
  requestAnimationFrame(d);
 }
 d();
})();

/* ── SCREEN ── */
function show(id){
 document.querySelectorAll('.scr').forEach(s=>{s.classList.add('out');setTimeout(()=>s.classList.remove('on','out'),500)});
 setTimeout(()=>{const t=document.getElementById(id);t.classList.add('on')},300);
}

/* ── SPLASH ── */
(function(){
 const f=document.getElementById('pb1'),p=document.getElementById('pp1'),l=document.getElementById('pl1');
 const lbs=['INITIALIZING...','LOADING CORE...','CONNECTING...','READY'];
 const s=performance.now(),d=2600;
 function e(t){return t<.5?4*t*t*t:1-Math.pow(-2*t+2,3)/2}
 function tick(n){
  const pr=Math.min((n-s)/d,1),ea=e(pr);
  f.style.width=(ea*100)+'%';p.textContent=Math.floor(ea*100)+'%';
  l.textContent=lbs[Math.min(Math.floor(ea*(lbs.length-1)),lbs.length-1)];
  if(pr<1)requestAnimationFrame(tick);
  else{p.textContent='100%';l.textContent='COMPLETE \u2713';setTimeout(()=>show('s2'),500);}
 }
 requestAnimationFrame(tick);
})();

/* ── BOOT SCREEN ── */
function bootScreen(cb){
 show('s3');
 const f=document.getElementById('pb2'),p=document.getElementById('pp2'),l=document.getElementById('pl2');
 const bs=['b1','b2','b3','b4','b5'],bls=['LOADING...','NETWORK...','INSTAGRAM API...','PROFILE...','DASHBOARD...'];
 const s=performance.now(),d=2400;
 function eo(t){return t===1?1:1-Math.pow(2,-10*t)}
 let li=-1;
 function tick(n){
  const pr=Math.min((n-s)/d,1),ea=eo(pr);
  f.style.width=(ea*100)+'%';p.textContent=Math.floor(ea*100)+'%';
  const idx=Math.min(Math.floor(ea*bs.length),bs.length-1);
  l.textContent=bls[Math.min(idx,bls.length-1)];
  if(idx>li){
   if(li>=0){const pv=document.getElementById(bs[li]);pv.classList.remove('a');pv.classList.add('d')}
   document.getElementById(bs[idx]).classList.add('a');li=idx;
  }
  if(pr<1)requestAnimationFrame(tick);
  else{p.textContent='100%';l.textContent='TAYYOR \u2713';setTimeout(cb,400);}
 }
 setTimeout(()=>requestAnimationFrame(tick),600);
}

/* ── TOAST ── */
let toastTimer;
function showToast(msg,isErr=false){
 const t=document.getElementById('toast');
 t.textContent=msg;
 t.className='show'+(isErr?' err':'');
 clearTimeout(toastTimer);
 toastTimer=setTimeout(()=>t.className='',2800);
}

/* ── RIPPLE ── */
function ripple(e){
 const btn=e.currentTarget||e.target.closest('button,.pkg,.atile');
 if(!btn)return;
 const r=document.createElement('span');
 r.className='ripple';
 const rc=btn.getBoundingClientRect(),sz=Math.max(rc.width,rc.height)*1.2;
 r.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+((e.clientX||rc.left+rc.width/2)-rc.left-sz/2)+'px;top:'+((e.clientY||rc.top+rc.height/2)-rc.top-sz/2)+'px';
 btn.appendChild(r);r.addEventListener('animationend',()=>r.remove());
}

/* ── EYE TOGGLE ── */
function toggleEye(id,btn){
 const inp=document.getElementById(id);
 inp.type=inp.type==='password'?'text':'password';
 btn.querySelector('svg').innerHTML=inp.type==='text'
  ?'<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>'
  :'<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
}

/* ── TABS ── */
let authMode='login';
function setTab(mode,el){
 authMode=mode;
 document.querySelectorAll('.ltab').forEach(t=>t.classList.remove('act'));
 el.classList.add('act');
 const btn=document.getElementById('lbtn');
 btn.querySelector('span').nextSibling.textContent=mode==='login'?'KIRISH':'RO\'YXATDAN O\'TISH';
 btn.lastChild.textContent=mode==='login'?'KIRISH':'RO\'YXATDAN O\'TISH';
}

/* ── AUTH ── */
async function doAuth(e){
 ripple(e);
 const u=document.getElementById('l-user').value.trim();
 const pw=document.getElementById('l-pass').value.trim();
 if(!u||!pw){showToast('Username va parol kiriting!',true);return;}

 const ov=document.getElementById('auth-ov');
 const s1=document.getElementById('st1'),s2=document.getElementById('st2'),s3=document.getElementById('st3');
 ov.classList.add('show');
 s1.className='stl a';s1.textContent='\u25B6 INSTAGRAM TEKSHIRILMOQDA...';
 s2.className='stl';s3.className='stl';

 const endpoint=authMode==='login'?'/api/login':'/api/register';
 try{
  const res=await fetch(API+endpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:u,password:pw})});
  const d=await res.json();
  if(!d.ok){
   ov.classList.remove('show');
   showToast(d.error||'Xato!',true);
   return;
  }
  s1.className='stl d';s1.textContent='\u2713 INSTAGRAM TEKSHIRILDI';
  s2.className='stl a';s2.textContent='\u25B6 SESSIYA OCHILMOQDA...';
  await delay(600);
  s2.className='stl d';s2.textContent='\u2713 SESSIYA OCHILDI';
  s3.className='stl a';s3.textContent='\u25B6 PROFIL YUKLANMOQDA...';
  await delay(500);
  ov.classList.remove('show');

  CUR.username=d.username;
  CUR.coins=d.coins||0;
  CUR.accounts=d.accounts||[u];

  bootScreen(loadDashboard);
 }catch(err){
  ov.classList.remove('show');
  showToast('Server bilan ulanishda xato!',true);
 }
}

/* ── DASHBOARD ── */
function loadDashboard(){
 show('s4');
 setTimeout(()=>{
  document.getElementById('dc1').classList.add('vis');
  document.getElementById('dc2').classList.add('vis');
  setTimeout(()=>document.getElementById('dc3').classList.add('vis'),150);
  setTimeout(()=>document.getElementById('sbw').classList.add('vis'),300);
 },200);
 updateCoinsUI();
 renderAccounts();
}

function updateCoinsUI(){
 ['d-coins','f-coins','st-coins','st-totalcoins'].forEach(id=>{
  const el=document.getElementById(id);
  if(el)el.textContent=CUR.coins.toLocaleString();
 });
}

/* ── AKKAUNTLAR ── */
function renderAccounts(){
 const wrap=document.getElementById('acc-rows');
 wrap.innerHTML='';
 CUR.accounts.forEach(acc=>{
  const row=document.createElement('div');
  row.className='urow';
  row.innerHTML=`
   <div class="uav">${acc.charAt(0).toUpperCase()}</div>
   <div class="uinf">
    <div class="unm">@${acc}</div>
    <div class="uco">&#11088; ${CUR.username===acc?CUR.coins.toLocaleString():'-'}</div>
   </div>
   <div class="tog on" style="width:36px;height:20px" onclick="this.classList.toggle('on')"><div class="tkn" style="transform:translateX(16px);width:14px;height:14px;top:2px"></div></div>
   ${acc!==CUR.username?`<div class="xbtn" onclick="removeAcc('${acc}',this)"><svg viewBox="0 0 14 14"><line x1="1" y1="1" x2="13" y2="13"/><line x1="13" y1="1" x2="1" y2="13"/></svg></div>`:''}
  `;
  wrap.appendChild(row);
 });
 document.getElementById('st-accs').textContent=CUR.accounts.length;
}

function removeAcc(acc,btn){
 const row=btn.closest('.urow');
 row.style.transition='all .4s';row.style.opacity='0';row.style.transform='translateX(20px)';
 setTimeout(()=>{
  CUR.accounts=CUR.accounts.filter(a=>a!==acc);
  renderAccounts();
 },400);
}

/* ── AKKAUNT QO'SHISH ── */
function addAccModal(){openModal('add-acc-modal')}

async function addAccount(e){
 ripple(e);
 const u=document.getElementById('na-user').value.trim();
 const pw=document.getElementById('na-pass').value.trim();
 if(!u||!pw){showToast('Ma\'lumotlar to\'liq emas!',true);return;}
 if(CUR.accounts.includes(u)){showToast('Bu akkaunt allaqachon qo\'shilgan!',true);return;}

 const btn=e.currentTarget||e.target.closest('button');
 btn.disabled=true;btn.textContent='TEKSHIRILMOQDA...';

 try{
  const res=await fetch(API+'/api/add_account',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({owner:CUR.username,username:u,password:pw})});
  const d=await res.json();
  if(!d.ok){showToast(d.error||'Xato!',true);}
  else{
   CUR.accounts.push(u);
   renderAccounts();
   closeModal('add-acc-modal');
   showToast('Akkaunt qo\'shildi! ✓');
   document.getElementById('na-user').value='';
   document.getElementById('na-pass').value='';
  }
 }catch(err){showToast('Server xatosi!',true);}
 btn.disabled=false;btn.innerHTML='<span class="bgl"></span>ULASH';
}

/* ── BOOST (LAUNCH) ── */
let boostRunning=false;
async function doBoost(e){
 ripple(e);
 if(boostRunning){showToast('Allaqachon ishlayapti!',true);return;}
 boostRunning=true;
 const btn=e.currentTarget||e.target.closest('button');
 const orig=btn.innerHTML;
 btn.innerHTML='<span class="bgl"></span>ISHLAMOQDA...';
 btn.disabled=true;

 try{
  const res=await fetch(API+'/api/boost',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:CUR.username})});
  const d=await res.json();
  if(d.ok){
   CUR.coins=d.total_coins;
   updateCoinsUI();
   showToast(d.message||'+tanga!');
   document.getElementById('st-follows').textContent=(parseInt(document.getElementById('st-follows').textContent||0)+d.follows).toString();
  }else{showToast(d.error||'Xato!',true);}
 }catch(err){showToast('Server bilan ulanishda xato!',true);}

 boostRunning=false;
 btn.disabled=false;btn.innerHTML=orig;
}

/* ── FOLLOWERS ── */
async function checkProfile(){
 const u=document.getElementById('f-user').value.trim();
 if(!u){showToast('Username kiriting!',true);return;}

 const profInfo=document.getElementById('prof-info');
 const pkgs=document.getElementById('pkgs');
 const pkgTitle=document.getElementById('pkg-title');
 const buyBtn=document.getElementById('buy-btn-wrap');
 profInfo.classList.remove('show');pkgs.classList.remove('show');
 pkgTitle.style.display='none';buyBtn.style.display='none';

 showToast('Profil tekshirilmoqda...');
 try{
  const res=await fetch(API+'/api/check_profile',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:u})});
  const d=await res.json();
  if(!d.ok){showToast(d.error||'Profil topilmadi!',true);return;}

  document.getElementById('prof-av').textContent=d.username.charAt(0).toUpperCase();
  document.getElementById('prof-name').textContent=d.full_name||d.username;
  document.getElementById('prof-fol').textContent=d.followers.toLocaleString()+' followers';
  profInfo.classList.add('show');
  pkgTitle.style.display='block';
  pkgs.classList.add('show');
  CUR.fTarget=d.username;
  CUR.pkg=null;
  document.querySelectorAll('.pkg').forEach(p=>p.classList.remove('sel'));
  buyBtn.style.display='none';
  showToast('Profil topildi ✓');
 }catch(err){showToast('Xato yuz berdi!',true);}
}

function selectPkg(el,id,amount,price){
 ripple({currentTarget:el,clientX:0,clientY:0});
 document.querySelectorAll('.pkg').forEach(p=>p.classList.remove('sel'));
 el.classList.add('sel');
 CUR.pkg={id,amount,price};
 document.getElementById('buy-btn-wrap').style.display='block';

 if(CUR.coins<price){
  showToast('Tangalar yetarli emas! Kerak: '+price.toLocaleString()+' tanga',true);
 }
}

async function buyFollowers(e){
 ripple(e);
 if(!CUR.fTarget){showToast('Avval username kiriting!',true);return;}
 if(!CUR.pkg){showToast('Paket tanlang!',true);return;}
 if(CUR.coins<CUR.pkg.price){
  showToast('Tangalar yetarli emas! Kerak: '+CUR.pkg.price.toLocaleString(),true);return;
 }

 const btn=e.currentTarget||e.target.closest('button');
 const orig=btn.innerHTML;
 btn.disabled=true;btn.innerHTML='<span class="bgl"></span>BUYURTMA BERILMOQDA...';

 try{
  const res=await fetch(API+'/api/buy_followers',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({buyer:CUR.username,target:CUR.fTarget,package_id:CUR.pkg.id})});
  const d=await res.json();
  if(d.ok){
   CUR.coins=d.coins_left;
   updateCoinsUI();
   showToast(d.message||'Buyurtma qabul qilindi!');
   document.querySelectorAll('.pkg').forEach(p=>p.classList.remove('sel'));
   document.getElementById('buy-btn-wrap').style.display='none';
   CUR.pkg=null;
   document.getElementById('st-orders').textContent=(parseInt(document.getElementById('st-orders').textContent||0)+1).toString();
  }else{showToast(d.error||'Xato!',true);}
 }catch(err){showToast('Server xatosi!',true);}
 btn.disabled=false;btn.innerHTML=orig;
}

/* ── PROMOCOD ── */
function promoModal(){openModal('promo-modal')}

async function usePromo(e){
 ripple(e);
 const code=document.getElementById('promo-code').value.trim().toUpperCase();
 if(!code){showToast('Promocod kiriting!',true);return;}

 const btn=e.currentTarget||e.target.closest('button');
 btn.disabled=true;

 try{
  const res=await fetch(API+'/api/use_promo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:CUR.username,code})});
  const d=await res.json();
  if(d.ok){
   CUR.coins=d.total_coins;
   updateCoinsUI();
   closeModal('promo-modal');
   document.getElementById('promo-code').value='';
   showToast(d.message||'+tanga!');
  }else{showToast(d.error||'Xato!',true);}
 }catch(err){showToast('Server xatosi!',true);}
 btn.disabled=false;
}

/* ── ADMIN ── */
function showAdmin(){openModal('admin-modal')}

async function loadAdminStats(){
 const key=document.getElementById('adm-key').value.trim();
 if(!key){showToast('Admin kalit kiriting!',true);return;}
 try{
  const res=await fetch(API+'/api/admin/stats',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({admin_key:key})});
  const d=await res.json();
  if(!d.ok){showToast(d.error||'Xato!',true);return;}
  document.getElementById('adm-users').textContent=d.users;
  document.getElementById('adm-accs').textContent=d.accounts;
  document.getElementById('adm-orders').textContent=d.orders;
  document.getElementById('adm-promos').textContent=d.promos;
  showToast('Statistika yuklandi ✓');
 }catch(err){showToast('Xato!',true);}
}

async function createPromo(e){
 ripple(e);
 const key=document.getElementById('adm-key').value.trim();
 const code=document.getElementById('adm-pcode').value.trim().toUpperCase();
 const amt=parseInt(document.getElementById('adm-pamt').value)||1000;
 if(!key){showToast('Admin kalit kiriting!',true);return;}

 const btn=e.currentTarget||e.target.closest('button');
 btn.disabled=true;

 try{
  const res=await fetch(API+'/api/admin/create_promo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({admin_key:key,code:code||'',amount:amt})});
  const d=await res.json();
  if(d.ok){
   showToast('Promocod yaratildi: '+d.code);
   // Ro'yxatga qo'shish
   const list=document.getElementById('promo-list');
   const wrap=document.getElementById('promo-list-wrap');
   wrap.style.display='block';
   const item=document.createElement('div');
   item.className='promo-item';
   item.innerHTML=`<span class="promo-code">${d.code}</span><span class="promo-amt">+${d.amount}&#11088;</span><span class="promo-exp">1 kun</span>`;
   list.insertBefore(item,list.firstChild);
   document.getElementById('adm-pcode').value='';
  }else{showToast(d.error||'Xato!',true);}
 }catch(err){showToast('Xato!',true);}
 btn.disabled=false;
}

/* ── NAV TABS ── */
function goTab(id,el){
 const navScreens=['s4','s5','s6'];
 navScreens.forEach(sid=>{
  const s=document.getElementById(sid);
  if(s.classList.contains('on')){s.classList.add('out');setTimeout(()=>s.classList.remove('on','out'),500);}
 });
 setTimeout(()=>document.getElementById(id).classList.add('on'),300);

 // Nav highlight
 const allNavs=document.querySelectorAll('.ni');
 allNavs.forEach(n=>n.classList.remove('act'));
 if(el){
  const myNav=el.closest('.ni')||el;
  myNav.classList.add('act');
  // Boshqa screendagi ham shu pozitsiyani highlight qilish
  const idx=Array.from(myNav.parentElement.children).indexOf(myNav);
  document.querySelectorAll('.nav').forEach(nav=>{
   const items=nav.querySelectorAll('.ni');
   if(items[idx])items[idx].classList.add('act');
  });
 }

 // Statistika yangilash
 if(id==='s6'){
  document.getElementById('st-totalcoins').textContent=CUR.coins.toLocaleString();
  document.getElementById('st-accs').textContent=CUR.accounts.length;
 }
 if(id==='s5')document.getElementById('f-coins').textContent=CUR.coins.toLocaleString();
}

/* ── MODAL ── */
function openModal(id){document.getElementById(id).classList.add('show')}
function closeModal(id){document.getElementById(id).classList.remove('show')}

/* ── UTILS ── */
function delay(ms){return new Promise(r=>setTimeout(r,ms))}

/* ── AUTO REFRESH COINS ── */
setInterval(async()=>{
 if(!CUR.username)return;
 try{
  const res=await fetch(API+'/api/get_coins',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:CUR.username})});
  const d=await res.json();
  if(d.ok&&d.coins!==CUR.coins){CUR.coins=d.coins;updateCoinsUI();}
 }catch(e){}
},15000);
</script>
