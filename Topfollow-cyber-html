      <div class="admin-stat"><div class="ast-title">FOYDALANUVCHILAR</div><div class="ast-val" id="adm-users">-</div></div>
      <div class="admin-stat"><div class="ast-title">AKKAUNTLAR</div><div class="ast-val" id="adm-accs">-</div></div>
      <div class="admin-stat"><div class="ast-title">BUYURTMALAR</div><div class="ast-val" id="adm-orders">-</div></div>
