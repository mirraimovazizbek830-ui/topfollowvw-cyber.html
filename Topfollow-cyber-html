<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>TopFollow // CYBER</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#03010a;--purple:#b400ff;--purple2:#7a00bb;--blue:#00d4ff;
  --green:#00ff9d;--pink:#ff00aa;--yellow:#ffe600;--red:#ff3055;
  --text:#e0e0ff;--dim:#7070aa;
  --glass:rgba(255,255,255,0.04);--gborder:rgba(180,0,255,0.25);
  --gp:0 0 20px rgba(180,0,255,0.6),0 0 60px rgba(180,0,255,0.2);
  --gb:0 0 20px rgba(0,212,255,0.6),0 0 60px rgba(0,212,255,0.2);
  --gg:0 0 20px rgba(0,255,157,0.6),0 0 60px rgba(0,255,157,0.2);
  --FD:'Orbitron',monospace;--FM:'Share Tech Mono',monospace;--FB:'Rajdhani',sans-serif;
  --tr:cubic-bezier(0.23,1,0.32,1)
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;background:#000;display:flex;align-items:center;justify-content:center;overflow:hidden;font-family:var(--FB)}
.dbg{position:fixed;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(90,0,180,.15) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(0,150,255,.08) 0%,transparent 50%),#000;display:flex;align-items:center;justify-content:center}
.phone{width:360px;height:780px;position:relative;overflow:hidden;border-radius:36px;box-shadow:0 0 0 1px rgba(180,0,255,.3),0 0 40px rgba(180,0,255,.2),0 0 80px rgba(0,212,255,.1),0 40px 80px rgba(0,0,0,.8);background:var(--bg)}
@media(max-width:400px){.phone{width:100vw;height:100vh;border-radius:0}}
#mc{position:absolute;inset:0;z-index:0;opacity:.18;pointer-events:none}
.scr{position:absolute;inset:0;z-index:1;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .5s var(--tr),transform .5s var(--tr);transform:translateY(12px);background:var(--bg)}
.scr.on{opacity:1;pointer-events:all;transform:none}
.scr.out{opacity:0;transform:translateY(-20px);pointer-events:none}
.scanline{position:absolute;inset:0;z-index:99;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.08) 2px,rgba(0,0,0,.08) 4px)}

/* SPLASH */
.sp-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%,rgba(180,0,255,.18) 0%,transparent 70%)}
.sp-logo{font-family:var(--FD);font-size:42px;font-weight:900;letter-spacing:4px;color:#fff;text-shadow:var(--gp);position:relative;z-index:2;animation:glitch 4s infinite 1s}
.sp-logo::before,.sp-logo::after{content:attr(data-t);position:absolute;inset:0}
.sp-logo::before{color:var(--blue);clip-path:polygon(0 0,100% 0,100% 35%,0 35%);left:2px;animation:gt 4s infinite 1s}
.sp-logo::after{color:var(--pink);clip-path:polygon(0 65%,100% 65%,100% 100%,0 100%);left:-2px;animation:gb2 4s infinite 1.2s}
@keyframes glitch{0%,90%,100%{transform:none}92%{transform:skewX(-1deg) translateX(2px)}94%{transform:skewX(1deg) translateX(-2px)}}
@keyframes gt{0%,90%,100%{opacity:0}92%{opacity:.8;transform:translateX(-3px)}94%{opacity:.8;transform:translateX(3px)}96%{opacity:0}}
@keyframes gb2{0%,90%,100%{opacity:0}93%{opacity:.7;transform:translateX(3px)}95%{opacity:.7;transform:translateX(-3px)}}
.sp-tag{font-family:var(--FM);font-size:10px;letter-spacing:3px;color:var(--green);opacity:.7;z-index:2;margin-top:4px}
.sp-eye{font-family:var(--FM);font-size:11px;letter-spacing:5px;color:var(--blue);opacity:.8;z-index:2;margin-bottom:8px}
.sp-wrap{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px;margin-bottom:60px}
.pbar-out{width:260px;height:3px;background:rgba(255,255,255,.06);border-radius:3px;position:relative;overflow:visible}
.pbar-in{height:100%;width:0%;border-radius:3px;background:linear-gradient(90deg,var(--purple),var(--blue));box-shadow:0 0 10px var(--blue),0 0 20px var(--purple);position:relative}
.pbar-in::after{content:'';position:absolute;right:-4px;top:50%;transform:translateY(-50%);width:8px;height:8px;border-radius:50%;background:#fff;box-shadow:0 0 8px var(--blue),0 0 16px var(--purple)}
.prow{display:flex;justify-content:space-between;width:260px}
.plbl{font-family:var(--FM);font-size:10px;color:var(--dim);letter-spacing:1px}
.ppct{font-family:var(--FM);font-size:12px;color:var(--blue)}
.sp-ver{position:absolute;bottom:24px;font-family:var(--FM);font-size:10px;color:var(--dim);letter-spacing:2px;z-index:2}

/* INPUTS */
.ig{position:relative}
.if{width:100%;height:52px;background:rgba(255,255,255,.03);border:1px solid rgba(180,0,255,.2);border-radius:12px;padding:18px 44px 6px 16px;font-family:var(--FB);font-size:15px;font-weight:600;color:var(--text);outline:none;transition:all .3s var(--tr);caret-color:var(--blue)}
.if::placeholder{color:transparent}
.if:focus{border-color:var(--purple);background:rgba(180,0,255,.05);box-shadow:0 0 0 2px rgba(180,0,255,.15),var(--gp)}
.il{position:absolute;left:16px;top:50%;transform:translateY(-50%);font-family:var(--FB);font-size:13px;font-weight:500;color:var(--dim);pointer-events:none;transition:all .25s var(--tr)}
.if:focus~.il,.if:not(:placeholder-shown)~.il{top:9px;transform:none;font-size:10px;letter-spacing:1px;color:var(--blue)}
.eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--dim);padding:4px}
.eye svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2}

/* BUTTONS */
.btn{width:100%;height:52px;border:none;border-radius:12px;background:linear-gradient(135deg,var(--purple2),var(--purple));color:#fff;font-family:var(--FD);font-size:12px;font-weight:700;letter-spacing:3px;cursor:pointer;position:relative;overflow:hidden;transition:all .3s var(--tr);box-shadow:var(--gp),0 8px 32px rgba(180,0,255,.4)}
.btn:hover{transform:translateY(-2px) scale(1.01)}
.btn:active{transform:scale(.97)}
.btn-g{background:linear-gradient(135deg,#006633,var(--green))}
.btn-b{background:linear-gradient(135deg,#003366,var(--blue))}
.btn-r{background:linear-gradient(135deg,#660011,var(--red))}
.ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.3);transform:scale(0);animation:rpl .6s linear;pointer-events:none}
@keyframes rpl{to{transform:scale(4);opacity:0}}

/* GLASS CARD */
.card{background:rgba(255,255,255,.03);border:1px solid rgba(180,0,255,.15);border-radius:16px;overflow:hidden;transition:opacity .5s var(--tr),transform .5s var(--tr),border-color .3s;opacity:0;transform:translateY(-12px)}
.card.vis{opacity:1;transform:none}
.card:hover{border-color:rgba(180,0,255,.4)}
.cacc{height:2px;background:linear-gradient(90deg,var(--purple),var(--blue));opacity:.6}

/* HEADER */
.hdr{width:100%;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.02);border-bottom:1px solid rgba(180,0,255,.12);flex-shrink:0;position:relative;z-index:2}
.hdr::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--purple),var(--blue),var(--green),transparent);opacity:.5}
.hlogo{font-family:var(--FD);font-size:13px;font-weight:700;color:#fff;letter-spacing:2px}
.coins-wrap{display:flex;gap:8px}
.cpill{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:4px 10px}
.cpill .ic{font-size:13px}
.cval{font-family:var(--FM);font-size:12px;color:#fff;min-width:44px;text-align:right}

/* NAV */
.nav{width:100%;flex-shrink:0;padding:6px 6px 14px;display:grid;grid-template-columns:repeat(4,1fr);background:rgba(0,0,0,.6);border-top:1px solid rgba(180,0,255,.1);backdrop-filter:blur(20px)}
.ni{display:flex;flex-direction:column;align-items:center;gap:3px;padding:7px 4px;cursor:pointer;border-radius:10px;position:relative;transition:all .25s var(--tr);opacity:.4}
.ni.act{opacity:1}
.ni.act::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:22px;height:2px;border-radius:1px;background:linear-gradient(90deg,var(--purple),var(--blue));box-shadow:0 0 8px var(--purple)}
.ni svg{width:20px;height:20px;stroke:var(--text);fill:none;stroke-width:1.8}
.ni.act svg{stroke:var(--purple);filter:drop-shadow(0 0 6px var(--purple))}
.ni span{font-family:var(--FB);font-size:9px;font-weight:600;color:var(--dim);letter-spacing:.5px}
.ni.act span{color:var(--purple)}
.ni.dis{opacity:.2;cursor:not-allowed}

/* SCROLL */
.scroll{flex:1;overflow-y:auto;overflow-x:hidden;padding:14px 14px 0;display:flex;flex-direction:column;gap:10px;scrollbar-width:none}
.scroll::-webkit-scrollbar{display:none}

/* OVERLAY */
.ov{position:absolute;inset:0;background:rgba(3,1,10,.93);backdrop-filter:blur(8px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;opacity:0;pointer-events:none;transition:opacity .3s;z-index:50;border-radius:inherit}
.ov.show{opacity:1;pointer-events:all}
.spin{width:52px;height:52px;position:relative}
.spin::before,.spin::after{content:'';position:absolute;border-radius:50%;border:2px solid transparent}
.spin::before{inset:0;border-top-color:var(--purple);border-right-color:var(--purple);animation:sa 1s linear infinite}
.spin::after{inset:7px;border-bottom-color:var(--blue);border-left-color:var(--blue);animation:sa .7s linear infinite reverse}
@keyframes sa{to{transform:rotate(360deg)}}
.stl{font-family:var(--FM);font-size:11px;color:var(--dim);letter-spacing:1px;transition:color .3s}
.stl.a{color:var(--green)}.stl.d{opacity:.5}

/* TOAST */
#toast{position:fixed;bottom:100px;left:50%;transform:translateX(-50%) translateY(20px);background:rgba(20,0,40,.95);border:1px solid var(--purple);border-radius:12px;padding:12px 24px;font-family:var(--FM);font-size:12px;color:var(--green);letter-spacing:1px;z-index:9999;opacity:0;transition:all .4s;pointer-events:none;white-space:nowrap;box-shadow:var(--gp)}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#toast.err{color:var(--red);border-color:var(--red);box-shadow:0 0 20px rgba(255,48,85,.4)}

/* MODAL */
.modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(6px);z-index:80;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s}
.modal-bg.show{opacity:1;pointer-events:all}
.modal{width:100%;background:linear-gradient(180deg,rgba(20,0,40,.98),rgba(3,1,10,.98));border-radius:24px 24px 0 0;border:1px solid rgba(180,0,255,.3);border-bottom:none;padding:24px 20px 32px;transform:translateY(100%);transition:transform .4s var(--tr)}
.modal-bg.show .modal{transform:translateY(0)}
.modal-title{font-family:var(--FD);font-size:15px;font-weight:700;color:#fff;letter-spacing:2px;text-align:center;margin-bottom:20px}
.modal-close{position:absolute;right:16px;top:16px;width:32px;height:32px;border-radius:10px;background:rgba(255,0,80,.15);border:1px solid rgba(255,0,80,.25);display:flex;align-items:center;justify-content:center;cursor:pointer}
.modal-close svg{width:14px;height:14px;stroke:var(--red);fill:none;stroke-width:2.5;stroke-linecap:round}

/* SCREEN 2 — LOGIN */
#s2{justify-content:flex-start}
.lhdr{width:100%;padding:48px 24px 38px;background:linear-gradient(160deg,rgba(100,0,200,.4) 0%,rgba(0,80,160,.2) 100%);display:flex;flex-direction:column;align-items:center;gap:6px;position:relative;border-bottom:1px solid var(--gborder)}
.lhdr::after{content:'';position:absolute;bottom:-1px;left:20%;right:20%;height:1px;background:linear-gradient(90deg,transparent,var(--purple),var(--blue),transparent);animation:scan 3s ease-in-out infinite}
@keyframes scan{0%,100%{opacity:.3}50%{opacity:1}}
.llogo{font-family:var(--FD);font-size:26px;font-weight:900;color:#fff;letter-spacing:3px;text-shadow:var(--gp)}
.lsub{font-family:var(--FM);font-size:10px;color:var(--green);letter-spacing:3px;opacity:.8}
.ibadge{width:62px;height:62px;border-radius:18px;background:var(--glass);border:1px solid var(--gborder);display:flex;align-items:center;justify-content:center;position:absolute;bottom:-31px;box-shadow:var(--gp),0 8px 32px rgba(0,0,0,.5);backdrop-filter:blur(12px);animation:ibp 3s ease-in-out infinite}
.ibadge svg{width:28px;height:28px;stroke:var(--purple);fill:none;stroke-width:1.5}
@keyframes ibp{0%,100%{box-shadow:var(--gp),0 8px 32px rgba(0,0,0,.5)}50%{box-shadow:var(--gb),0 8px 32px rgba(0,0,0,.5)}}
.lform{width:100%;padding:50px 20px 16px;flex:1;display:flex;flex-direction:column;gap:12px;position:relative}
.ltabs{display:flex;gap:0;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:3px;margin-bottom:4px}
.ltab{flex:1;padding:8px;border-radius:8px;font-family:var(--FD);font-size:10px;font-weight:700;letter-spacing:1px;color:var(--dim);cursor:pointer;text-align:center;transition:all .3s;border:none;background:none}
.ltab.act{background:var(--purple);color:#fff;box-shadow:var(--gp)}
.lftr{text-align:center;padding:0 20px 20px;font-family:var(--FM);font-size:10px;color:var(--dim);line-height:1.8}

/* SCREEN 3 — BOOT */
#s3{gap:36px}
.blog{font-family:var(--FD);font-size:30px;font-weight:900;letter-spacing:4px;color:#fff;text-shadow:var(--gp)}
.bsub{font-family:var(--FM);font-size:10px;letter-spacing:4px;color:var(--green);opacity:.7;margin-top:4px}
.bsteps{display:flex;flex-direction:column;gap:6px;width:280px;margin-top:12px}
.bsi{display:flex;align-items:center;gap:10px;font-family:var(--FM);font-size:10px;color:var(--dim);opacity:.4;transition:all .3s}
.bsi.a{color:var(--green);opacity:1}.bsi.d{opacity:.6}
.bdot{width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0}
.bsi.a .bdot{box-shadow:0 0 8px var(--green);animation:dp .8s infinite alternate}
@keyframes dp{to{transform:scale(1.5)}}

/* SCREEN 4 — DASHBOARD */
#s4{justify-content:flex-start}
/* ACTION TILES */
.atiles{padding:14px;display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.atile{display:flex;flex-direction:column;align-items:center;gap:7px;padding:13px 7px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.05);border-radius:12px;cursor:pointer;transition:all .25s var(--tr)}
.atile:hover{background:rgba(180,0,255,.08);border-color:rgba(180,0,255,.3);transform:translateY(-2px)}
.atile:active{transform:scale(.95)}
.aico{width:40px;height:40px;border-radius:11px;background:rgba(180,0,255,.12);border:1px solid rgba(180,0,255,.2);display:flex;align-items:center;justify-content:center}
.aico svg{width:19px;height:19px;stroke:var(--purple);fill:none;stroke-width:1.8}
.atile:nth-child(2) .aico{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.2)}
.atile:nth-child(2) .aico svg{stroke:var(--blue)}
.atile:nth-child(3) .aico{background:rgba(255,224,0,.08);border-color:rgba(255,224,0,.15)}
.atile:nth-child(3) .aico svg{stroke:var(--yellow)}
.albl{font-family:var(--FB);font-size:10px;font-weight:600;color:var(--dim);text-align:center;letter-spacing:.4px}
/* ANTI-BAN */
.abwrap{padding:14px 18px;display:flex;align-items:center;justify-content:space-between}
.abl{display:flex;align-items:center;gap:10px}
.tog{width:44px;height:24px;border-radius:12px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);position:relative;cursor:pointer;transition:all .3s}
.tog.on{background:rgba(0,255,157,.2);border-color:var(--green);box-shadow:0 0 12px rgba(0,255,157,.3)}
.tkn{width:18px;height:18px;border-radius:50%;background:var(--dim);position:absolute;top:2px;left:2px;transition:all .3s var(--tr)}
.tog.on .tkn{transform:translateX(20px);background:var(--green);box-shadow:var(--gg)}
.abt{font-family:var(--FD);font-size:11px;font-weight:700;color:var(--text);letter-spacing:1px}
.abs{font-family:var(--FM);font-size:10px;color:var(--green);opacity:.8;margin-top:2px}
/* USER ROWS */
.urows{padding:10px 14px;display:flex;flex-direction:column;gap:8px}
.urow{display:flex;align-items:center;gap:10px;padding:9px 10px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.05);border-radius:11px;transition:all .3s}
.urow:hover{border-color:rgba(180,0,255,.25)}
.uav{width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,var(--purple),var(--blue));display:flex;align-items:center;justify-content:center;font-family:var(--FD);font-size:14px;font-weight:900;color:#fff;box-shadow:var(--gp);flex-shrink:0;animation:avs 6s ease-in-out infinite}
@keyframes avs{0%,100%{background:linear-gradient(135deg,var(--purple),var(--blue))}50%{background:linear-gradient(135deg,var(--blue),var(--purple))}}
.uinf{flex:1}
.unm{font-family:var(--FB);font-size:13px;font-weight:700;color:var(--text)}
.uco{font-family:var(--FM);font-size:10px;color:var(--yellow);letter-spacing:1px}
.xbtn{width:26px;height:26px;border-radius:8px;background:rgba(255,0,80,.1);border:1px solid rgba(255,0,80,.2);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .25s;flex-shrink:0}
.xbtn:hover{background:rgba(255,0,80,.25);box-shadow:0 0 10px rgba(255,0,80,.3)}
.xbtn svg{width:11px;height:11px;stroke:rgba(255,80,80,.9);fill:none;stroke-width:2.5;stroke-linecap:round}
/* START BTN */
.sbwrap{padding:8px 14px;flex-shrink:0;width:100%;opacity:0;transition:opacity .5s .4s}
.sbwrap.vis{opacity:1}
.sbtn{width:100%;height:54px;border:none;border-radius:14px;background:linear-gradient(135deg,#6600cc,var(--purple),#3300bb);color:#fff;font-family:var(--FD);font-size:13px;font-weight:700;letter-spacing:4px;cursor:pointer;position:relative;overflow:hidden;box-shadow:var(--gp),0 8px 32px rgba(180,0,255,.4);animation:bg 2.5s ease-in-out infinite;transition:transform .3s}
.sbtn:hover{transform:translateY(-3px)}
.sbtn:active{transform:scale(.97)}
@keyframes bg{0%,100%{box-shadow:var(--gp),0 8px 32px rgba(180,0,255,.4)}50%{box-shadow:0 0 40px rgba(180,0,255,.9),0 12px 48px rgba(180,0,255,.6)}}
.bgl{position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.12) 0%,transparent 60%)}
.bfl{position:absolute;inset:0;background:rgba(255,255,255,.06);animation:bf 8s linear infinite}
@keyframes bf{0%,95%,100%{opacity:0}96%{opacity:1}97%{opacity:0}98%{opacity:.5}}

/* SCREEN 5 — FOLLOWERS */
#s5{justify-content:flex-start}
.fwrap{width:100%;padding:20px 18px;display:flex;flex-direction:column;gap:14px;flex:1;overflow-y:auto;scrollbar-width:none}
.fwrap::-webkit-scrollbar{display:none}
.finput-row{display:flex;gap:8px;align-items:flex-end}
.finput-row .ig{flex:1}
.fok{height:52px;min-width:64px;border:none;border-radius:12px;background:linear-gradient(135deg,var(--purple2),var(--purple));color:#fff;font-family:var(--FD);font-size:11px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:all .3s;box-shadow:var(--gp);padding:0 14px}
.fok:hover{transform:translateY(-2px)}
.profile-info{background:rgba(255,255,255,.03);border:1px solid rgba(0,212,255,.2);border-radius:14px;padding:14px;display:flex;align-items:center;gap:12px;display:none}
.profile-info.show{display:flex}
.pav{width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-family:var(--FD);font-size:18px;font-weight:900;color:#fff;flex-shrink:0}
.pinf{flex:1}
.pname{font-family:var(--FB);font-size:14px;font-weight:700;color:var(--text)}
.pfol{font-family:var(--FM);font-size:10px;color:var(--blue);letter-spacing:1px;margin-top:2px}
.pkg-title{font-family:var(--FD);font-size:11px;font-weight:700;color:var(--text);letter-spacing:2px;margin-top:4px}
.pkgs{display:flex;flex-direction:column;gap:8px;display:none}
.pkgs.show{display:flex}
.pkg{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;background:rgba(255,255,255,.03);border:1px solid rgba(180,0,255,.2);border-radius:14px;cursor:pointer;transition:all .3s;position:relative;overflow:hidden}
.pkg:hover{border-color:var(--purple);background:rgba(180,0,255,.08);transform:translateY(-2px)}
